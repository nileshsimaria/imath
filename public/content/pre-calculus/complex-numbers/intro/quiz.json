    {
      "id": "q12",
      "type": "multiple-choice",
      "promptTex": "\\dfrac{(1 + i)}{(1 - i)} = ?",
      "choices": [
        "$i$",
        "$-i$",
        "$1$",
        "$-1$"
      ],
      "answerIndex": 0,
      "hints": [
        "Multiply top and bottom by $(1 + i)$.",
        "Top: $(1 + i)^2 = 1 + 2i - 1 = 2i$. Bottom: $(1)^2 + (1)^2 = 2$. Result: $2i/2 = i$."
      ],
      "explanation": "$\\dfrac{(1+i)^2}{(1-i)(1+i)} = \\dfrac{2i}{2} = i$.",
      "steps": [
        {
          "text": "**Multiply top and bottom by conjugate** $(1 + i)$:"
        },
        {
          "math": "\\dfrac{(1 + i)(1 + i)}{(1 - i)(1 + i)}"
        },
        {
          "text": "**Numerator:** $(1 + i)^2 = 1 + 2i + i^2 = 1 + 2i - 1 = 2i$."
        },
        {
          "text": "**Denominator:** $1 - i^2 = 1 + 1 = 2$."
        },
        {
          "math": "= \\dfrac{2i}{2} = i"
        }
      ],
      "difficulty": "medium"
    },
