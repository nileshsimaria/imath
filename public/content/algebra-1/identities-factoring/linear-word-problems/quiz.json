    {
      "id": "q8",
      "type": "numeric",
      "promptTex": "\\text{Sum of digits of two-digit number is 8. If digits are reversed, new number is } 18 \\\\ \\text{less than original. Find the original number.}",
      "answer": 53,
      "tolerance": 0.001,
      "hints": [
        "Let tens digit = $a$, units = $b$. Original = $10a + b$, reverse = $10b + a$.",
        "$a + b = 8$. $(10a + b) - (10b + a) = 18 \\Rightarrow 9a - 9b = 18 \\Rightarrow a - b = 2$.",
        "Add: $2a = 10, a = 5$, $b = 3$. Number: 53."
      ],
      "explanation": "Tens 5, units 3. Original 53. Reverse 35. 53 - 35 = 18 ✓.",
      "steps": [
        {
          "text": "**Variables.** Tens digit $a$, units $b$. Original number $= 10a + b$, reversed $= 10b + a$."
        },
        {
          "text": "**Equation 1:** $a + b = 8$."
        },
        {
          "text": "**Equation 2:**"
        },
        {
          "math": "(10a + b) - (10b + a) = 18"
        },
        {
          "math": "9a - 9b = 18 \\;\\Longrightarrow\\; a - b = 2"
        },
        {
          "text": "**Solve.** Add the two equations: $2a = 10 \\Rightarrow a = 5$, $b = 3$. Original number: $53$."
        }
      ],
      "difficulty": "hard"
    },
