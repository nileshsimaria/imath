      "promptTex": "\\text{A bag has } 25 \\text{ coins of } \\$2 \\text{ and } \\$5 \\text{ totaling } \\$95. \\\\ \\text{How many } \\$5 \\text{ coins?}",
      "answer": 15,
      "tolerance": 0.001,
      "hints": [
        "Let \\$5 coins = $x$. \\$2 coins = $25 - x$.",
        "$5x + 2(25 - x) = 95 \\Rightarrow 3x + 50 = 95 \\Rightarrow x = 15$."
      ],
      "explanation": "15 coins of \\$5 (= \\$75) + 10 coins of \\$2 (= \\$20) = \\$95. ✓",
      "steps": [
        {
          "text": "**Let number of \\$5 coins be $x$.** Then \\$2 coins = $25 - x$."
        },
        {
          "text": "**Value equation:**"
        },
        {
          "math": "5x + 2(25 - x) = 95"
        },
        {
          "math": "5x + 50 - 2x = 95 \\;\\Longrightarrow\\; 3x = 45 \\;\\Longrightarrow\\; x = 15"
        }
      ],
      "difficulty": "medium"
    },
