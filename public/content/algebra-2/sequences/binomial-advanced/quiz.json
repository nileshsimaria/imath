        },
        {
          "text": "**Set $x = 1$:**"
        },
        {
          "math": "n \\cdot 2^{n-1} = \\sum_k k \\binom{n}{k}"
        },
        {
          "text": "**Plug in $n = 8$:**"
        },
        {
          "math": "8 \\cdot 2^7 = 8 \\cdot 128 = 1024"
        }
