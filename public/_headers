# Security headers for Cloudflare Pages.
# This file is copied verbatim from public/ into dist/ by Vite, and Cloudflare
# Pages applies it to every response. See:
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  # --- Content Security Policy ---
  # script-src 'self'        : all JS is bundled by Vite; there are no inline
  #                            scripts or event handlers, so no 'unsafe-inline'.
  # style-src  'unsafe-inline': required — KaTeX and d3 (function-plot) emit
  #                            inline style="" attributes on rendered elements.
  # connect-src/font-src/img-src 'self': the app only fetches its own JSON,
  #                            fonts, and SVG; nothing is loaded cross-origin.
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; upgrade-insecure-requests

  # --- Clickjacking ---
  X-Frame-Options: DENY

  # --- MIME-sniffing ---
  X-Content-Type-Options: nosniff

  # --- Referrer leakage ---
  Referrer-Policy: strict-origin-when-cross-origin

  # --- Force HTTPS for 2 years. Drop includeSubDomains if other subdomains
  #     of the apex domain are not (yet) HTTPS-only. Add `; preload` only once
  #     you are certain — it is hard to undo.
  Strict-Transport-Security: max-age=63072000; includeSubDomains

  # --- Disable browser features the app never uses ---
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()

  # --- Cross-origin isolation hardening ---
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
